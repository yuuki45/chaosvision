{
  "_comment_1": "このファイルをコピーして secrets.json を作成してください。secrets.json は .gitignore 済。",
  "_comment_2": "値は worker/ をデプロイした後に決まります。詳細は worker/README.md。",
  "_comment_3": "  CHAOS_WORKER_URL: `npx wrangler deploy` の出力 URL",
  "_comment_4": "  CHAOS_APP_SECRET: `npx wrangler secret put APP_SECRET` で登録した文字列",
  "_comment_5": "実行時: flutter run -d <device> --dart-define-from-file=secrets.json",
  "_comment_6": "ビルド時: flutter build ipa --dart-define-from-file=secrets.json",

  "CHAOS_WORKER_URL": "https://chaos-vision-proxy.<your-subdomain>.workers.dev",
  "CHAOS_APP_SECRET": "replace-with-the-app-secret-you-generated"
}
