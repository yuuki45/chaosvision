# Environment files
.env
.env.local
.env.*.local

# API Keys (security)
**/api_keys/
**/*api_key*
**/*secret*

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.flutter-plugins-dependencies*
.pub-cache/
.pub/
/build/
ios/build/
ios/Pods/
ios/.symlinks/
android/.gradle/
android/build/
android/app/build/

# Generated mocks (regenerate with build_runner)
**/*.mocks.dart

# Tooling caches (Serena MCP, etc.)
.serena/

# Finder duplicates
**/* 2
**/* 2.*

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
